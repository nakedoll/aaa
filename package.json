{
  "name": "kcea-member-manager",
  "version": "1.0.0",
  "description": "한국콘텐츠기업협회 회원관리 시스템",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "package:win": "npm run build && electron-builder --win",
    "package:mac": "npm run build && electron-builder --mac && npm run sign:mac",
    "sign:mac": "node scripts/sign-mac.mjs",
    "postinstall": "electron-builder install-app-deps"
  },
  "devDependencies": {
    "electron": "43.0.0-beta.8",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.3.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.0.0"
  },
  "allowScripts": {
    "better-sqlite3@12.11.1": true,
    "electron@43.0.0-beta.8": true,
    "esbuild@0.21.5": true,
    "fsevents@2.3.3": true
  }
}
